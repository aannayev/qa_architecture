# ──────────────────────────────────────────────────────────────
# Core configuration — copy to .env and adjust as needed.
# Every variable has a sensible default so the stack runs
# without any edits on a fresh clone.
# ──────────────────────────────────────────────────────────────

# Project
PROJECT_NAME=qa-architect
ENVIRONMENT=local
LOG_LEVEL=INFO

# Postgres (shared instance, schema-per-service)
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_SUPER_USER=postgres
POSTGRES_SUPER_PASSWORD=postgres

# Per-service credentials (created by init script)
HISTORY_DB_NAME=history
HISTORY_DB_USER=history
HISTORY_DB_PASSWORD=history

PHYSICS_DB_NAME=physics
PHYSICS_DB_USER=physics
PHYSICS_DB_PASSWORD=physics

MATH_DB_NAME=math
MATH_DB_USER=math
MATH_DB_PASSWORD=math

GEOGRAPHY_DB_NAME=geography
GEOGRAPHY_DB_USER=geography
GEOGRAPHY_DB_PASSWORD=geography

ORCHESTRATOR_DB_NAME=orchestrator
ORCHESTRATOR_DB_USER=orchestrator
ORCHESTRATOR_DB_PASSWORD=orchestrator

AI_ASSISTANT_DB_NAME=ai_assistant
AI_ASSISTANT_DB_USER=ai_assistant
AI_ASSISTANT_DB_PASSWORD=ai_assistant

UNLEASH_DB_NAME=unleash
UNLEASH_DB_USER=unleash
UNLEASH_DB_PASSWORD=unleash

# Redis (AI assistant session state + rate limit)
REDIS_HOST=redis
REDIS_PORT=6379

# Gateway
TRAEFIK_HTTP_PORT=80
TRAEFIK_DASHBOARD_PORT=8080

# Frontend
FRONTEND_PORT=3000
VITE_API_BASE_URL=http://localhost/api
VITE_AI_WS_URL=ws://localhost/ai/v1/assist

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://otel-collector:4317
OTEL_SERVICE_NAME_HISTORY=history-service
OTEL_SERVICE_NAME_PHYSICS=physics-service
OTEL_SERVICE_NAME_MATH=math-service
OTEL_SERVICE_NAME_GEOGRAPHY=geography-service
OTEL_SERVICE_NAME_ORCHESTRATOR=exam-orchestrator
OTEL_SERVICE_NAME_AI=ai-assistant

GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
GRAFANA_PORT=3001
PROMETHEUS_PORT=9090

# Feature flags (Unleash)
UNLEASH_URL=http://unleash:4242/api
UNLEASH_API_TOKEN=default:development.unleash-insecure-api-token
UNLEASH_ADMIN_TOKEN=*:*.unleash-insecure-admin-token
UNLEASH_PORT=4242

# ──────────────────────────────────────────────────────────────
# LLM configuration
# Default is MOCK — deterministic responses, no network calls.
# To use real Claude: set LLM_PROVIDER=claude + ANTHROPIC_API_KEY.
# ──────────────────────────────────────────────────────────────
LLM_PROVIDER=mock
LLM_MODEL=claude-opus-4-6
LLM_MAX_TOKENS=600
LLM_TEMPERATURE=0.4
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# AI Assistant guardrails
AI_RATE_LIMIT_PER_SESSION=20
AI_RATE_LIMIT_PER_MINUTE=5
AI_ANSWER_LEAK_SIMILARITY_THRESHOLD=0.85

# AI in CI (mock by default)
CLAUDE_MAX_TOKENS_PER_JOB=20000
AI_CI_MODE=mock

# Blue/Green traffic weights (0–100)
BLUE_WEIGHT=100
GREEN_WEIGHT=0
